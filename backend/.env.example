# ─── AI Provider Selection ─────────────────────────────────────────────────────
# Change ONE variable to swap the entire provider — no code changes required.
#
#   AI_LLM_PROVIDER:          anthropic | openai
#   AI_EMBEDDER_PROVIDER:     anthropic | openai
#   AI_VECTOR_STORE_PROVIDER: chroma    | faiss

AI_LLM_PROVIDER=anthropic
AI_EMBEDDER_PROVIDER=anthropic
AI_VECTOR_STORE_PROVIDER=chroma

# ─── Models ────────────────────────────────────────────────────────────────────
# anthropic LLM:    claude-opus-4-7 | claude-sonnet-4-6 | claude-haiku-4-5-20251001
# openai LLM:       gpt-4o | gpt-4o-mini | google/gemma-4-31b (LM Studio)
# anthropic embed:  voyage-3 | voyage-3-lite
# openai embed:     text-embedding-3-small | text-embedding-nomic-embed-text-v1.5

AI_LLM_MODEL=claude-sonnet-4-6
AI_EMBEDDING_MODEL=voyage-3

# ─── API Keys ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...           # or "lm-studio" for LM Studio (any non-empty string)
OPENAI_BASE_URL=                # leave empty for OpenAI; set http://localhost:1234/v1 for LM Studio
VOYAGE_API_KEY=pa-...           # Voyage AI embeddings; falls back to ANTHROPIC_API_KEY if empty

# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./cbnest.db

# ─── JWT ───────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ─── Vector Store ──────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma_db
ANONYMIZED_TELEMETRY=False       # suppress ChromaDB telemetry warnings

# ─── File Paths ────────────────────────────────────────────────────────────────
POLICY_UPLOAD_DIR=./data/policies

# ─── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
BACKEND_BASE_URL=http://localhost:8000

# ─── AI Generation Token Limits ────────────────────────────────────────────────
# Tune these when switching models (especially reasoning models that consume
# thinking tokens before output). See app/core/config.py for correlation rules.
#
# Correlations to maintain:
#   SMART_COPILOT_INTENT  ≥  SQL_AGENT_QUERY           (reasoning overhead)
#   SQL_AGENT_SUMMARY     ≈  0.5 × SQL_AGENT_QUERY     (brief summary)
#   POLICY_RAG_ANSWER     =  HR_DATA_RAG_ANSWER         (same answer format)
#   POLICY_RAG_ANSWER     ≈  2 × SQL_AGENT_QUERY        (prose vs SQL)
#   ACTION_AGENT_EXTRACT  =  POLICY_RAG_ANSWER           (same output budget)
#   ACTION_AGENT_SUMMARY  ≈  0.5 × ACTION_AGENT_EXTRACT (brief summary)

AI_MAX_TOKENS_SMART_COPILOT_INTENT=512
AI_MAX_TOKENS_SQL_AGENT_QUERY=512
AI_MAX_TOKENS_SQL_AGENT_SUMMARY=256
AI_MAX_TOKENS_POLICY_RAG_ANSWER=1024
AI_MAX_TOKENS_HR_DATA_RAG_ANSWER=1024
AI_MAX_TOKENS_ACTION_AGENT_EXTRACT=1024
AI_MAX_TOKENS_ACTION_AGENT_SUMMARY=500
AI_SEMANTIC_ROUTER_THRESHOLD=0.85  # hybrid: semantic handles clear intents; LLM fallback for ambiguous ones
